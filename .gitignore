# Service account key + anything else secret
secrets/
!secrets/.gitignore

# Actual sheet config (contains private sheet URL) — commit sheet-config.example.json instead
sheet-config.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Logs
tracker-log.txt
*.log

# Playwright MCP runtime artifacts
.playwright-mcp/

# Local Claude Code settings (personal overrides)
.claude/settings.local.json

# OS cruft
Thumbs.db
.DS_Store
